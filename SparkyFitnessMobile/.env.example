APP_VARIANT=development

# Optional app identity overrides
APP_NAME=SparkyFitness
APP_SLUG=sparkyfitnessmobile
IOS_BUNDLE_IDENTIFIER=com.yourname.sparkyfitness
IOS_DEV_BUNDLE_IDENTIFIER=com.yourname.sparkyfitness.dev
ANDROID_PACKAGE=org.yourname.sparkyfitness
ANDROID_DEV_PACKAGE=org.yourname.sparkyfitness.dev
IOS_APPLE_TEAM_ID=YOURTEAMID

# Safe to embed: this is used only to prefill the server URL on first launch.
# Use your Mac's LAN IP, not localhost, when connecting from an iPhone.
DEFAULT_SERVER_URL=http://192.168.1.50:8080

# Development builds can talk to local HTTP servers. Leave true for local testing.
IOS_ALLOW_HTTP_IN_DEV=true
